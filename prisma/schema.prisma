generator client {
  provider = "prisma-client-js" // Corrigido de "prisma-client" para o padrão
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  ADMIN
  USER
  GUEST
}

enum TypePerson {
  STAFF
  MEMBER
  VISITOR
  VOLUNTEER
}

enum DayOfWeek {
  DOMINGO
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}

// Novo Enum para separar Entradas e Saídas (útil para o futuro)
enum EntryType {
  INCOME
  EXPENSE
}

enum JourneyTriggerType {
  MANUAL
  PROFILE_COMPLETED
  ONBOARDING_COMPLETED
  FIRST_ATTENDANCE
  ATTENDANCE_STREAK
  JOINED_MINISTRY
  JOINED_GROUP
  FIRST_PRAYER_REQUEST
  SCALE_CONFIRMED
}

enum VolunteerScaleResponseStatus {
  PENDING
  CONFIRMED
  DECLINED
  SWAP_REQUESTED
}

enum NotificationType {
  VOLUNTEER_ASSIGNED_TO_SCALE
  VOLUNTEER_CONFIRMED_SCALE
  VOLUNTEER_DECLINED_SCALE
  VOLUNTEER_REQUESTED_SWAP
}

model Church {
  id      String   @id @default(uuid())
  name    String
  label   String   @unique
  address String
  contact String[]
  customization Json?

  // --- NOVOS CAMPOS PARA O FINANCEIRO (PIX) ---
  pixKeyType   String? // Ex: "email", "cnpj", "phone"
  pixKeyValue  String? // Ex: "igreja@contato.com"
  pixCopyPaste String? // Armazena o código BR Code se necessário

  // Relações
  users            User[]
  persons          Person[]
  links            ChurchLink[]
  schedules        WeeklySchedule[]
  ministries       Ministry[]
  volunteerScales  VolunteerScale[]
  notifications    Notification[]
  financialEntries FinancialEntry[] // Nova relação financeira

  journeyStages JourneyStage[]
  journeyAchievements JourneyAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- NOVA MODEL: ENTRADAS FINANCEIRAS ---
model FinancialEntry {
  id          String    @id @default(uuid())
  amount      Float // Valor da doação/entrada
  category    String // Ex: "tithe" (dízimo), "offering", "missions"
  type        EntryType @default(INCOME)
  date        DateTime  @default(now())
  donorName   String? // Nome do doador (opcional para entradas manuais)
  description String? // Observações/Descrição

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId])
}

model ChurchLink {
  id     String  @id @default(uuid())
  title  String
  url    String
  icon   String?
  active Boolean @default(true)
  order  Int     @default(0)

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId])
}

model WeeklySchedule {
  id          String    @id @default(uuid())
  title       String
  dayOfWeek   DayOfWeek
  time        String
  description String?
  active      Boolean   @default(true)

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId])
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  role          SystemRole  @default(USER)
  status        TypePerson? @default(MEMBER)

  churchId  String?
  youChurch Church? @relation(fields: [churchId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  accounts  Account[]
  notificationsReceived Notification[] @relation("UserNotifications")
  notificationsTriggered Notification[] @relation("NotificationActor")

  @@map("user")
}

model Person {
  id       String     @id @default(uuid())
  name     String
  email    String?
  contact  String[]
  address  String?
  birthday String?
  type     TypePerson @default(MEMBER)
  profileImage String?

  ministry String?
  role     String?

  notes        String?
  firstVisitAt DateTime? @default(now())
  onboardingDraft       Json?
  onboardingCompletedAt DateTime?

  churchId  String
  youChurch Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  journey         PersonJourney?
  journeyTasks    PersonJourneyTask[]
  achievements    PersonAchievement[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  volunteerScales VolunteerScale[]

  @@unique([email, churchId])
}

model Ministry {
  id          String  @id @default(uuid())
  name        String
  description String?
  icon        String?
  color       String? @default("#8ee4af")

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  scales VolunteerScale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, churchId])
}

model VolunteerScale {
  id             String                       @id @default(uuid())
  date           DateTime
  role           String
  eventName      String?
  confirmed      Boolean                      @default(false)
  responseStatus VolunteerScaleResponseStatus @default(PENDING)
  responseNote   String?
  respondedAt    DateTime?

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  ministryId String
  ministry   Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId])
  @@index([personId])
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  link        String?
  entityType  String?
  entityId    String?
  metadata    Json?
  readAt      DateTime?

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  recipientUserId String
  recipientUser   User @relation("UserNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId, recipientUserId, createdAt(sort: Desc)])
  @@index([recipientUserId, readAt])
  @@index([entityType, entityId])
}

model JourneyStage {
  id              String   @id @default(uuid())
  key             String
  name            String
  description     String
  order           Int
  active          Boolean  @default(true)
  visibleToMember Boolean  @default(true)
  pointsReward    Int      @default(0)

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  tasks           JourneyTask[]
  currentJourneys PersonJourney[] @relation("CurrentJourneyStage")
  historyEntries  PersonJourneyStageHistory[] @relation("StageHistoryTo")
  previousEntries PersonJourneyStageHistory[] @relation("StageHistoryFrom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([churchId, key])
  @@unique([churchId, order])
  @@index([churchId, active])
}

model JourneyTask {
  id          String             @id @default(uuid())
  key         String
  title       String
  description String
  points      Int                @default(0)
  required    Boolean            @default(true)
  active      Boolean            @default(true)
  triggerType JourneyTriggerType @default(MANUAL)

  stageId String
  stage   JourneyStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  progressEntries PersonJourneyTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stageId, key])
  @@index([stageId, active])
}

model JourneyAchievement {
  id          String   @id @default(uuid())
  key         String
  name        String
  description String
  icon        String
  points      Int      @default(0)
  active      Boolean  @default(true)

  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  personAchievements PersonAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([churchId, key])
  @@index([churchId, active])
}

model PersonJourney {
  id             String   @id @default(uuid())
  score          Int      @default(0)
  level          Int      @default(1)
  progress       Int      @default(0)
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  lastActivityAt DateTime?

  personId String @unique
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  currentStageId String?
  currentStage   JourneyStage? @relation("CurrentJourneyStage", fields: [currentStageId], references: [id], onDelete: SetNull)

  tasks   PersonJourneyTask[]
  history PersonJourneyStageHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currentStageId])
}

model PersonJourneyTask {
  id          String             @id @default(uuid())
  completed   Boolean            @default(false)
  completedAt DateTime?
  source      JourneyTriggerType @default(MANUAL)

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  journeyId String
  journey   PersonJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  taskId String
  task   JourneyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([journeyId, taskId])
  @@index([personId, completed])
}

model PersonAchievement {
  id       String   @id @default(uuid())
  earnedAt DateTime @default(now())

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   JourneyAchievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([personId, achievementId])
  @@index([personId])
}

model PersonJourneyStageHistory {
  id      String             @id @default(uuid())
  movedAt DateTime           @default(now())
  notes   String?
  source  JourneyTriggerType @default(MANUAL)

  journeyId String
  journey   PersonJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  fromStageId String?
  fromStage   JourneyStage? @relation("StageHistoryFrom", fields: [fromStageId], references: [id], onDelete: SetNull)

  toStageId String
  toStage   JourneyStage @relation("StageHistoryTo", fields: [toStageId], references: [id], onDelete: Cascade)

  @@index([journeyId, movedAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
